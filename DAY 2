{
    public static void main(String[] args)
    {
        Scanner s=new Scanner(System.in);
        int k=s.nextInt();
        if(k==0|| k<0)
        return;
        PriorityQueue<Integer> pq=new PriorityQueue<>();
        for(int i=0;i<k;i++)
        {
            int n=s.nextInt();
            for(int j=0;j<n;j++)
            {
                pq.add(s.nextInt());
            }
        }
       StringBuilder sb = new StringBuilder();
        while (!pq.isEmpty()) {
