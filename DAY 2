5.Identify the Trusted Leader (Town Judge)  trust[i] = [a, b] → person a trusts person b
// You are using Java
import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int n = s.nextInt();
        int m = s.nextInt();
        int[] indegree = new int[n + 1];
        int[] outdegree = new int[n + 1];
        for (int i = 0; i < m; i++) {
            int a = s.nextInt();
            int b = s.nextInt();

            outdegree[a]++; 
            indegree[b]++;  
        }
        for (int i = 1; i <= n; i++) {
            if (indegree[i] == n - 1 && outdegree[i] == 0) {
                System.out.println(i);
                return;
            }
        }
        System.out.println(-1);
    }
}

