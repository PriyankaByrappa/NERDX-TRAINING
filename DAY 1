3.import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();
        String t = sc.nextLine();

        // 1. Calculate frequencies
        int[] countS = getFrequency(s);
        int[] countT = getFrequency(t);

        // 2. Check if they are anagrams
        if (Arrays.equals(countS, countT)) {
            System.out.println("Valid Anagram");
        } else {
            System.out.println("Invalid Anagram");
        }

        // 3. Print sorted frequencies
        System.out.println("S: " + formatFrequency(countS));
        System.out.println("T: " + formatFrequency(countT));
    }

    // Helper to count lowercase 'a'-'z'
    private static int[] getFrequency(String str) {
        int[] freq = new int[26];
        for (char c : str.toCharArray()) {
            freq[c - 'a']++;
        }
        return freq;
    }
    
    // Helper to format output as "char:count char:count"
    private static String formatFrequency(int[] freq) {
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < 26; i++) {
            if (freq[i] > 0) {
                if (sb.length() > 0) sb.append(" ");
                sb.append((char) (i + 'a')).append(":").append(freq[i]);
            }
        }
        return sb.toString();
    }
}

